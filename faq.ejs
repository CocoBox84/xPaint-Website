      width: 120px;
      margin-left: 40px;
      max-width: 100%;
    }

    .Welcome-text-left {
      color: rgb(80, 80, 80);
      font-size: 40px;
      display: inline;
      float: left;
    }

    #Welcome-text {
      color: rgb(80, 80, 80);
      font-size: 40px;
      text-align: center;
    }

