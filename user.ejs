                    <img style="border: 2px solid black; margin-right: 15px;" width="100" height="100" src="/users/<%= user1.username %>/pfp">
                    <h3><a href="/users/<%= user1.username %>/"><%= user1.username %></a>
                      <% if (user) { %>
