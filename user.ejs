      text-shadow: 0 1px #fff;
      font-family: Arial, Helvetica, sans-serif;
      background-color: white;
      margin: 12px;
      box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.418);
      overflow-y: auto;
      overflow-x: hidden;
      padding: 0px !important;
      height: 100vh;
      margin: -3px;
      width: 240px;
      transition: width 200ms;
