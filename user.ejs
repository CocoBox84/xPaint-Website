    </div>

    <div id="container">
      <div id="user-box">
        <div class="user-box-head">
          <h3>
            <span><%= username %>'s profile</span>
            <span style="float: right;">

              <% if (user) { %>
              <% const isUserFollowing = user.following.some(f => f.username === username) %>
              <% if (isUserFollowing) { %>
              <a href="/api/unfollow/<%= username %>/"><button class="special-button">Unfollow</button></a>
              <% } else { %>
              <a href="/api/follow/<%= username %>/"><button class="special-button">Follow</button></a>
              <% } %>

              <% if ((user) && username != user.username) { %><button class="special-button" onclick="navBoxOpen('messages', 'to=<%= username %>')">Send Message</button><% } %>
              <% } %>
            </span>
          </h3>
        </div>
        <div class="user-box" id="user-info">
          <div>
            <div id="left-box" class="box-push-into-left" style="padding: 10px !important;">
              <h4>Some stuff to know about <br><a href="/users/<%= username %>/"><%= username %></a>!: </h4>
              <% if (isEditable) { %>
              <button class="special-button" onclick="document.getElementById('left-box').classList.toggle('edit'); setTimeout(function() {document.getElementById('edit-img-box').classList.toggle('edit'); document.getElementById('edit-des-box').classList.toggle('edit'); document.getElementById('user-description').classList.toggle('edit');}, 200)">Edit</button><br>
              <style>
                #edit-img-box {
                  display: none !important;
                }

                #edit-img-box.edit {
                  display: block !important;
                  border: 2px black solid !important;
                  width: 300px !important;
                  height: 300px !important;
                }

                #edit-des-box {
                  display: none !important;
                }

                #user-description {
                  display: block !important;
                }

                #edit-des-box.edit {
                  display: block !important;
                }

                #user-description.edit {
                  display: none !important;
                }
              </style>

              </style>
              <div id="edit-img-box" style="max-width: 300px !important; max-height: 300px !important; overflow-y: scroll !important; overflow-x: scroll !important;">
                <h1>Upload an Image</h1>
                <form id="imageForm">
                  <input type="file" id="imageInput" accept="image/*" />
                  <div id="previewContainer">
                    <img id="imagePreview" src="" alt="Image Preview" style="max-width: 300px; display: none;" />
                  </div>
                  <button class="special-button" type="submit">Upload</button>
                </form>

                <script>
                  const username = "<%= user.username %>";
                  document.addEventListener("DOMContentLoaded", () => {
                    const imageInput = document.getElementById("imageInput");
                    const imagePreview = document.getElementById("imagePreview");
                    const imageForm = document.getElementById("imageForm");

                    // Preview the image
                    imageInput.addEventListener("change", (event) => {
                      const file = event.target.files[0];
                      if (file) {
                        const reader = new FileReader();
                        reader.onload = (e) => {
                          imagePreview.src = e.target.result;
                          imagePreview.style.display = "block";
                        };
                        reader.readAsDataURL(file);
                      }
                    });

                    // Handle form submission
                    imageForm.addEventListener("submit", async (event) => {
                      event.preventDefault();

                      const file = imageInput.files[0];
                      if (!file) {
                        alert("Please select an image to upload.");
                        return;
                      }

                      const formData = new FormData();
                      formData.append("pfp", file);

                      try {
                        const response = await fetch(`/users/${username}/changePfp/`, {
                          method: "POST",
                          body: formData,
                        });

                        if (response.ok) {
                          alert("Image uploaded successfully!");
                          window.location.href = window.location.href;
                        } else {
                          alert("Failed to upload image.");
                        }
                      } catch (error) {
                        console.error("Error uploading image:", error);
                        alert("An error occurred while uploading the image.");
                      }
                    });
                  });
                </script>
              </div>
              <% } %>
              <img src="/users/<%= username %>/pfp" style="border: black 2px solid;" width="100px" height="100px">
              <div style="padding: 3px; margin: 9px;">
                <span>Joined: <%= user2.created_at %></span>
                <% if (isEditable) { %>
                <h4>My description: </h4>
                <% } %>
                <p id="user-description"><%= user2.description %></p>
                <% if (isEditable) { %>
                <div id="edit-des-box">
                  <textarea inputmode="url" id="description" wrap="off" style="white-space: pre; overflow-x: auto; min-width: 279px !important; min-height: 233px !important; max-width: 382px !important;"><%= user2.description %></textarea>
                  <h3>CocoScript:</h3>
                  <p>Use CocoScript to style your pages and add interactivity.</p>
                  <textarea id="Coco-Script-area" wrap="off" style="white-space: pre; overflow-x: auto; min-width: 279px !important; min-height: 233px !important; max-width: 382px !important;"><% if (user2.script) { %><%- user2.script %> <% } %></textarea>
                  <br>
                  <button onclick="RunCocoScript()">Test Script</button>
                  <h4>CocoScript Output:</h4>
                  <ul id="CocoScript's-special-output"></ul>
                  <button onclick="window.document.getElementById('CocoScript\'s-special-output').innerHTML = '';">Clear Output</button>
                  <button class="special-button" onclick="updateProfile();">Update</button>
