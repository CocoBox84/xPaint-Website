              <div id="e" class="error big-box"></div>
            </div>
          </div>
        </div>
        <% if (user) { %>
        <script>
          localStorage.setItem("poopUsername", "<%= user.username %>");
        </script>
        <% } %>
        <script src="/CocoScript.js"></script>
        <script>
          function RunCocoScript() {
            CocoScript.run(document.getElementById("Coco-Script-area").value);
          }
        </script>
        <% if (user) { %>
        <script>
          CocoScript.run(`!username = "<%= user.username %>";`)
        </script>
        <% } %>
        <% if (user2.script && ((user) && user.CocoScriptEnabled === 'true')) { %><script>
          setTimeout(function(event) {
            RunCocoScript();
          }, 2000);
        </script><% } %>
        <script src="/Scripts/user.js"></script>
        <script src="/Ambler.mp3Sound.js"></script>
        <script src="/JS/global.js"></script>
        <!-- Initialize @.js -->
        <script src="/JS/@.js"></script>
        <script>
          setTimeout(function() {
            window.document.getElementById("user-description").innerHTML = new Amp().linkify(window.document.getElementById("user-description").innerHTML);
            window.document.getElementById("user-description").innerHTML = new Amp().Stickerify(window.document.getElementById("user-description").innerHTML);
          });

          async function getUserProjects(isOnHomePage = false) {
            const isCoco = (isOnHomePage) ? "Coco-projects" : "user-projects";
            const res = await fetch("/api/list/projects/<%= username %>/");
            if (res.status === 200) {
              /*@param {}*/
              const projects = await res.json() || [];
              if (!projects || projects.length < 1) return;
              const projectList = document.getElementById(isCoco);
              projectList.innerHTML = "";
              projects.forEach(project => {
                projectList.innerHTML += `
                <a style="display: contents; word-break: break-all;" href="/projects/${project.id}/">
                  <div style="border: 2px solid black;">
                    <div style="border-bottom: 2px solid black; height: 200px;">
                      <img src="/api/projects/${project.id}/thumbnail/" alt="Project Image" width="100%" height="100%">
                    </div>
                    <div style="display: flex;">
                      <div style="padding: 5px; flex: 2;">
                        <h4 style="margin: 0px; margin-bottom: 5px;">${project.name}</h4>
                        by <a href="/users/${project.owner.username}/">${project.owner.username}</a>
                      </div>
                      <div>
                        <a href="/users/${project.owner.username}/">
                          <img src="/users/${project.owner.username}/pfp/" alt="User ${project.owner.username}'s Profile Picture" width="50px" height="50px" style="border: 2px black solid !important;border-radius: 50%; margin: 7px;">
                        </a>
                      </div>
                    </div>
                  </div>
                </a>
              `;
              });
              projectList.innerHTML = new Amp().Stickerify(projectList.innerHTML);
            }
          }

          getUserProjects();
        </script>
</body>

