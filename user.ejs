                      <span>
                        <% if (!user.following.some(f => f.username === user1.username)) { %> <button class="special-button follow_unfollow" data-username="<%= user1.username %>" onclick="followUser('<%= user1.username %>');">Follow User</button>
                        <% } else { %><button class="special-button follow_unfollow" data-username="<%= user1.username %>" onclick="unfollowUser('<%= user1.username %>');">Unfollow User</button><% } %>
