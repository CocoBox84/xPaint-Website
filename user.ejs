  min-height: 300px;
  /* Stretch between header and footer */
  flex: 1;">
                <div style="border: black 2px solid !important;   /* Stretch in the remaining horizontal space */
  flex: 2;
  /* Critical: enable vertical scrolling inside */
  overflow: auto;
  /* Critical: allow the scrolling area to shrink within the flex container */
  min-height: 0;
  min-height: 300px;
  /* Optional styling */
  background: white;
  border: 1px solid #ddd;
  padding: 1rem;">
                  <h3>Liked Projects</h3>
                  <ul id="liked-projects" style="border: 2px solid black; display: grid; grid-template-columns: 1fr 1fr; row-gap: 10px; column-gap: 10px; padding: 10px; background-color: white;">
                    No projects to display!
